{
  "name": "job-search",
  "version": "1.9.0",
  "description": "Runs the end-to-end job hunt: queries job-board APIs, LinkedIn, ATS feeds and career pages, tracks applications, kicks off resume-tailor, and surfaces warm-intro connections at target companies",
  "type": "tool",
  "category": "career",
  "complexity": "advanced",
  "tags": ["job-search", "career", "linkedin", "resume", "tracker", "applications", "job-hunt", "python", "greenhouse", "lever", "ashby", "smartrecruiters", "recruitee", "workable", "career-pages", "ats-discovery", "workday", "apify", "linkedin-connections", "warm-intro", "network"],
  "install": {
    "files": [
      { "src": "SKILL.md", "dest": "~/.claude/skills/job-search.md" },
      { "src": "scripts/job_tool.py", "dest": "~/.claude/skills/job-search/scripts/job_tool.py" },
      { "src": "references/search-fallbacks.md", "dest": "~/.claude/skills/job-search/references/search-fallbacks.md" }
    ]
  },
  "requirements": {
    "platform": "any",
    "mcp_servers": ["apify (optional)", "playwright (optional)"],
    "env_vars": ["APIFY_TOKEN (optional)"],
    "python": ">=3.9"
  }
}
