      { "src": "scripts/package.json", "dest": "~/.claude/skills/linkedin-project-adder/scripts/package.json" }
    ]
  },
  "requirements": {
    "platform": "any",
    "mcp_servers": [],
    "env_vars": [],
    "cli_tools": ["node", "npm"]
  }
}
